---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefix = lang === 'en' ? '' : `/${lang}`;
---
<nav class="fixed top-0 left-0 right-0 z-[100] px-8 py-4 bg-bg-primary/80 backdrop-blur-xl border-b border-border-custom flex items-center justify-between">
	<a href={`${prefix}/`} class="flex items-center gap-3 no-underline">
		<img src="/logo.svg" alt="Carrily Logo" class="w-[150px] h-auto" />
	</a>
	<ul class="hidden md:flex gap-8 list-none">
		<li><a href={`${prefix}#features`} class="text-text-secondary no-underline text-[0.9rem] font-medium transition-colors hover:text-accent">{t('nav.features')}</a></li>
		<li><a href={`${prefix}#how-it-works`} class="text-text-secondary no-underline text-[0.9rem] font-medium transition-colors hover:text-accent">{t('nav.howItWorks')}</a></li>
		<li><a href={`${prefix}#download`} class="text-text-secondary no-underline text-[0.9rem] font-medium transition-colors hover:text-accent">{t('nav.download')}</a></li>
    <li class="flex items-center gap-2 text-[0.8rem] ml-4 bg-white/5 px-2 py-0.5 rounded-full border border-white/5">
      <a href="/" class:list={[lang === 'en' ? 'text-accent' : 'text-text-muted hover:text-white transition-colors']}>EN</a>
      <span class="text-text-muted">|</span>
      <a href="/es/" class:list={[lang === 'es' ? 'text-accent' : 'text-text-muted hover:text-white transition-colors']}>ES</a>
    </li>
	</ul>
	<a href={`${prefix}#download`} class="bg-accent text-white px-5 py-2 rounded-full font-semibold text-[0.85rem] no-underline transition-all hover:brightness-110 hover:-translate-y-px hover:shadow-[0_4px_20px_var(--accent-glow)]">{t('nav.getApp')}</a>
</nav>
