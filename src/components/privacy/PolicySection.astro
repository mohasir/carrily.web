---
interface Props {
  number: number;
  title: string;
}

const { number, title } = Astro.props;
---

<section>
  <h2 class="text-[1.5rem] font-bold text-accent mt-12 mb-6 pb-2 border-b border-border-custom light:text-[#0284c7] light:border-[#e4e4e7]">
    {number}. {title}
  </h2>
  <div class="space-y-6">
    <slot />
  </div>
</section>
