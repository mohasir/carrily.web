---
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import SectionLayout from '@layouts/SectionLayout.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<SectionLayout id="download" class="text-center">
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full h-[400px] bg-[radial-gradient(circle,var(--color-accent-glow)_0%,transparent_70%)] pointer-events-none"></div>
  
  <div class="max-w-[700px] mx-auto bg-bg-card/30 backdrop-blur-3xl border border-white/5 rounded-[40px] p-8 md:p-16 relative z-10 shadow-[0_40px_100px_rgba(0,0,0,0.4)] overflow-hidden">
    <div class="absolute -top-32 -left-32 w-64 h-64 bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-32 -right-32 w-64 h-64 bg-purple/10 rounded-full blur-3xl pointer-events-none"></div>

    <h2 class="text-[clamp(2rem,5vw,3rem)] font-extrabold tracking-tight mb-6 leading-tight">{t('download.title')}</h2>
    <p class="text-text-secondary mb-12 text-[clamp(1rem,2vw,1.1rem)] max-w-[480px] mx-auto">{t('download.subtitle')}</p>
    
    <div class="flex flex-wrap justify-center gap-6">
      <a href="https://play.google.com/store/apps/details?id=com.mohasir.carrily" class="transition-all hover:scale-105 active:scale-95">
        <img src="/Google_Play_Store_badge.png" alt="Get it on Google Play" class="h-14 md:h-16 w-auto" />
      </a>
    </div>
  </div>
</SectionLayout>
