---
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import SectionHeader from '@home/SectionHeader.astro';
import SectionLayout from '@layouts/SectionLayout.astro';

import { getSteps } from '../content/steps';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const steps = getSteps(t);
---
<SectionLayout id="how-it-works" containerClass="max-w-[1000px]">
  <SectionHeader 
    label={t('howItWorks.label')} 
    title={t('howItWorks.title')} 
    description={t('howItWorks.description')}
  />
  
  <div class="relative flex flex-col gap-12 md:gap-16 mx-auto w-fit px-6 md:px-4">
    <!-- Vertical Gradient Line -->
    <div class="absolute left-[39px] top-6 bottom-6 w-[2px] bg-gradient-to-b from-accent via-purple to-transparent opacity-50 hidden md:block"></div>

    {steps.map((step, index) => (
      <div class:list={["flex flex-col md:flex-row items-center md:items-start text-center md:text-left gap-6 md:gap-10 animate relative", step.delay]}>
        <div class="w-12 h-12 min-w-[48px] rounded-full bg-black border-2 border-accent flex items-center justify-center font-bold text-[1.1rem] text-accent relative z-10 shadow-[0_0_15px_rgba(79,195,247,0.2)]">
          {index + 1}
        </div>
        <div class="pt-2">
          <h3 class="text-[1.3rem] md:text-[1.4rem] font-bold mb-3 text-white tracking-tight">{step.title}</h3>
          <p class="text-text-secondary text-[1rem] md:text-[1.05rem] leading-relaxed max-w-[650px]">
            {step.desc}
          </p>
        </div>
      </div>
    ))}
  </div>
</SectionLayout>
