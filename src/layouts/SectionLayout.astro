---
interface Props {
  id?: string;
  class?: string;
  containerClass?: string;
  isFullWidth?: boolean;
}

const { 
  id, 
  class: className, 
  containerClass,
  isFullWidth = false 
} = Astro.props;
---

<section id={id} class:list={["py-24 md:py-32 px-6 md:px-8 relative", className]}>
  <div class:list={[
    !isFullWidth ? "max-w-[1200px] mx-auto" : "w-full",
    containerClass
  ]}>
    <slot />
  </div>
</section>
